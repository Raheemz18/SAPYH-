{
  "entities": {
    "User": {
      "title": "User",
      "description": "A profile in the SA Padel Youth Hub (Player, Parent, or Organizer).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["player", "parent", "organizer", "admin"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "instagram": { "type": "string", "description": "Player only" },
        "age": { "type": "number", "description": "Player only" },
        "location": { "type": "string", "description": "Player only" },
        "category": { "type": "string", "description": "Player only" },
        "parentName": { "type": "string", "description": "Parent only" },
        "parentSurname": { "type": "string", "description": "Parent only" },
        "childName": { "type": "string", "description": "Parent only" },
        "childSurname": { "type": "string", "description": "Parent only" },
        "username": { "type": "string", "description": "Parent only" },
        "organizationName": { "type": "string", "description": "Organizer only" },
        "status": { "type": "string", "enum": ["pending", "approved"], "description": "Organizer only" }
      },
      "required": ["uid", "role", "email", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user alert for tournaments or ranking changes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["tournament", "ranking", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string", "description": "Optional link to a page." }
      },
      "required": ["id", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles indexed by their Auth UID."
    },
    "/users/{uid}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Individual alerts for a specific user."
    }
  }
}
